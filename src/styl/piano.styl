// ==================================================
// Piano
// ==================================================

// --------------------------------------------------
// Header / Stage
// --------------------------------------------------

.header
  background $bg-deep
  overflow hidden
  position relative

  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    bottom 0
    background radial-gradient(ellipse 80% 60% at 50% 110%, rgba($gold, .07) 0%, transparent 65%)
    pointer-events none
    z-index 0

// --------------------------------------------------
// Piano Body
// --------------------------------------------------

// @stylint off
.piano
  background linear-gradient(180deg, #09090f 0%, #0c0c18 35%, #101020 65%, #14142a 100%)
  border-top 3px solid $gold
  box-shadow 0 -6px 32px rgba($gold, .1), inset 0 0 80px rgba(0, 0, 0, .5)
  display flex
  height 80vh
  justify-content center
  overflow hidden
  padding-bottom 4%
  padding-left 2.5%
  padding-right 2.5%
  position relative
  z-index 1

  @media screen and (min-height $screen-xs)
    height $piano-height

  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    height 3px
    background linear-gradient(90deg, transparent 0%, $gold-light 50%, transparent 100%)
    opacity .55
    z-index 3
    pointer-events none

  &::after
    content ''
    position absolute
    top 3px
    left 0
    right 0
    height 10px
    background linear-gradient(180deg, rgba($gold, .07) 0%, transparent 100%)
    z-index 3
    pointer-events none

  // --------------------------------------------------
  // Key group
  // --------------------------------------------------

  &-key
    flex 1
    margin 0 ($space-xxs / 4)
    max-width $space-xxlg
    position relative

    +below('xxs')
      &:nth-child(1)
      &:nth-child(2)
      &:nth-child(3)
      &:nth-child(11)
      &:nth-child(12)
      &:nth-child(13)
      &:nth-child(14)
        display none

  // --------------------------------------------------
  // White Key
  // --------------------------------------------------

  &-key__white
    background linear-gradient(175deg, #e6e0cf 0%, #ede8d8 20%, #f4f0e4 55%, #f8f4ea 80%, #faf6ee 100%)
    border 1px solid rgba(0, 0, 0, .16)
    border-top none
    border-radius 0 0 6px 6px
    box-shadow inset 0 1px 0 rgba($white, .85), inset -1px 0 0 rgba(0, 0, 0, .05), inset 1px 0 0 rgba($white, .5), 0 7px 20px rgba(0, 0, 0, .6), 0 2px 5px rgba(0, 0, 0, .4)
    cursor pointer
    height 100%
    position relative
    transition box-shadow .05s ease, height .05s ease, background .05s ease, top .05s ease
    user-select none

    &:active,
    &.active
      background linear-gradient(175deg, #d2ccbb 0%, #d9d3c2 20%, #e2dccc 55%, #e6e0d0 80%, #e8e2d2 100%)
      box-shadow inset 0 1px 0 rgba($white, .55), inset -1px 0 0 rgba(0, 0, 0, .05), inset 1px 0 0 rgba($white, .35), 0 3px 10px rgba(0, 0, 0, .6), 0 0 16px rgba($gold, .22), 0 0 5px rgba($gold, .3)
      height 'calc(%s)' % (100% - $space-xxs)
      position relative
      top -($space-xxs)

  // --------------------------------------------------
  // White key labels
  // --------------------------------------------------

  &-key__white .key-note
    bottom 3.4rem
    color rgba(0, 0, 0, .22)
    font-size 1rem
    font-weight 700
    left 50%
    letter-spacing .04rem
    pointer-events none
    position absolute
    text-align center
    transform translateX(-50%)
    transition color .05s ease
    user-select none
    z-index $zindex-labels

  &-key__white .key-shortcut
    bottom 1rem
    color rgba(0, 0, 0, .16)
    font-size .85rem
    font-weight 500
    left 50%
    pointer-events none
    position absolute
    text-align center
    transform translateX(-50%)
    user-select none
    z-index $zindex-labels

  &-key__white:active .key-note,
  &-key__white.active .key-note
    color rgba(0, 0, 0, .32)

  // --------------------------------------------------
  // Black Key
  // --------------------------------------------------

  &-key__black
    background linear-gradient(175deg, #1e1e2c 0%, #161622 30%, #0f0f18 65%, #0a0a12 100%)
    border none
    border-radius 0 0 5px 5px
    box-shadow inset 0 1px 0 rgba($white, .07), inset -1px 0 0 rgba($white, .04), inset 1px 0 0 rgba(0, 0, 0, .45), 2px 8px 18px rgba(0, 0, 0, .75), 1px 2px 5px rgba(0, 0, 0, .55)
    cursor pointer
    height 60%
    left 100%
    position absolute
    transform translateX(-50%)
    top 0
    transition box-shadow .05s ease, background .05s ease, height .05s ease
    user-select none
    width 70%
    z-index $zindex-piano

    &:active,
    &.active
      background linear-gradient(175deg, #141420 0%, #0e0e1c 30%, #09090f 65%, #060609 100%)
      box-shadow inset 0 1px 0 rgba($white, .04), inset -1px 0 0 rgba($white, .02), 2px 3px 8px rgba(0, 0, 0, .75), 0 0 16px rgba($gold, .28), 0 0 5px rgba($gold, .38)
      height 'calc(%s)' % (60% - $space-xxs)

  // --------------------------------------------------
  // Black key label
  // --------------------------------------------------

  &-key__black .key-note
    bottom 0.9rem
    color rgba($white, .22)
    font-size .8rem
    font-weight 700
    left 50%
    letter-spacing .03rem
    pointer-events none
    position absolute
    text-align center
    transform translateX(-50%)
    user-select none
    z-index $zindex-labels

  &-key__black .key-shortcut
    display none

  &-key__black:active .key-note,
  &-key__black.active .key-note
    color rgba($gold, .65)
// @stylint on
