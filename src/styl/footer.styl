// --------------------------------------------------
// Footer
// --------------------------------------------------

.footer
  align-items center
  background $bg-deep
  border-top 1px solid rgba($gold, .15)
  color $gray-medium
  display flex
  font-size 1.4rem
  height $footer-height
  justify-content center
  letter-spacing .04rem

  &__link
    color $gold
    font-weight 600
    text-decoration none
    transition color .2s ease

    &:focus,
    &:hover
      color $gold-light
      text-decoration none
