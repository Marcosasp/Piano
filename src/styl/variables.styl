// ==================================================
// Variables
//
// 1. Colors
// 2. Spaces
// 3. Media Queries
// 4. zIndex
// ==================================================

// --------------------------------------------------
// 1. Colors
// --------------------------------------------------

$bg-deep      = #07070f
$bg-surface   = #0d0d1c
$bg-card      = #14142a

$gray-darker  = #0d0d1a
$gray-dark    = #1a1a2e
$gray         = #5858a0
$gray-medium  = #8080b0
$gray-light   = #aaaacc
$gray-lighter = #ccccdd
$gray-white   = #e8e8f5
$white        = #ffffff

$gold         = #c9a84c
$gold-light   = #e8c870
$gold-dim     = rgba(201, 168, 76, .2)
$gold-glow    = rgba(201, 168, 76, .12)

$teal         = #0d9cb5
$teal-light   = #4dd4eb
$red          = #e05252
$green        = #52cc7a
$blue         = $teal
$blue-light   = $teal-light

// Piano-specific key colors
$key-white    = #f5f0e0
$key-black    = #111118

// -------------------------------------------------
// 2. Spaces
// --------------------------------------------------

$space-xxs     = .4rem
$space-xs      = .8rem
$space-sm      = 1.6rem
$space         = 2.4rem
$space-md      = 3.2rem
$space-lg      = 4.8rem
$space-xlg     = 6.4rem
$space-xxlg    = 8.8rem

$piano-height  = 58vh
$footer-height = 5.6rem

// --------------------------------------------------
// 3. Media Queries
// --------------------------------------------------

$screen-xxs  = 380px  // xExtra small screen / phone
$screen-xs   = 440px  // Extra small screen / phone
$screen-sm   = 768px  // Small screen / tablet
$screen-md   = 992px  // Medium screen / desktop
$screen-lg   = 1200px // Large screen / wide desktop
$screen-xlg  = 1400px // Extra Large screen / wide desktop
$screen-xxlg = 1600px // Extra Large screen / wide desktop

// Rupture Settings
// @stylint off
rupture.mobile-cutoff  = $screen-sm
rupture.tablet-cutoff  = $screen-md
rupture.desktop-cutoff = $screen-lg
rupture.hd-cutoff      = $screen-xlg

rupture.scale          = 0 $screen-xxs $screen-sm $screen-md $screen-lg $screen-xlg $screen-xxlg
rupture.scale-names    = 'xxs' 'xs' 'sm' 'md' 'lg' 'xlg' 'hd'
rupture.anti-overlap   = -1px
// @stylint on

// --------------------------------------------------
// 4. zIndex
// --------------------------------------------------

$zindex-piano   = 1
$zindex-labels  = 2
$zindex-site    = 10
