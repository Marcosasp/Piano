// --------------------------------------------------
// Main
// --------------------------------------------------

.main
  background $bg-surface
  min-height 'calc(99vh - %s)' % ($piano-height + $footer-height)
  padding-bottom $space-lg
  padding-top $space-lg
  position relative
  z-index $zindex-site

  &::before
    content ''
    position absolute
    top 0
    left 0
    right 0
    height 1px
    background linear-gradient(90deg, transparent 0%, $gold 50%, transparent 100%)
    opacity .25

.content
  display flex
  flex-direction column

  &__links
    display flex
    align-items center
    gap $space-sm
    margin-bottom $space

  &__info
    display flex
    flex-wrap wrap
    gap $space-sm
    margin-top $space

.info-card
  align-items flex-start
  background $bg-card
  border 1px solid rgba($gold, .12)
  border-radius 8px
  display flex
  flex 1
  gap $space-sm
  min-width 180px
  padding $space-sm $space
  transition border-color .2s ease, box-shadow .2s ease

  &:hover
    border-color rgba($gold, .3)
    box-shadow 0 0 20px rgba($gold, .06)

  &__icon
    font-size 2.4rem
    line-height 1
    padding-top 2px

  &__text
    display flex
    flex-direction column
    gap $space-xxs

    strong
      color $gray-white
      font-size 1.4rem
      font-weight 600

    p
      color $gray-medium
      font-size 1.3rem
      line-height 1.5

